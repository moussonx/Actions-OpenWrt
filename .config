CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 1. 虚拟机与 SSD 核心加速 (针对 DS920+/923+ VMM)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_PACKAGE_fstrim=y
CONFIG_TARGET_OPTIMIZATION="-Os -pipe"

# 2. 网络核心与防火墙 (FW4 架构)
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-compat=y

# 3. 调度加速 (BBR + SQM)
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_TCP_CONG_HYBLA=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y

# 4. 科学上网核心：Passwall2 (保持 26.4.20-1)
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Sing-Box=y

# 5. Docker 与 Python3 环境 (支持容器化部署)
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_luci-app-docker-compose=y
CONFIG_PACKAGE_python3=y
CONFIG_PACKAGE_python3-pip=y

# 6. 极致穿透：异地组网三剑客 (Tailscale + ZeroTier + Cloudflared)
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y
CONFIG_PACKAGE_luci-app-cloudflared=y
CONFIG_PACKAGE_luci-i18n-cloudflared-zh-cn=y

# 7. 存储与共享 (Alist/Aria2/Samba4/FileBrowser/Rclone)
CONFIG_PACKAGE_luci-app-alist=y
CONFIG_PACKAGE_luci-i18n-alist-zh-cn=y
CONFIG_PACKAGE_luci-app-aria2=y
CONFIG_PACKAGE_luci-i18n-aria2-zh-cn=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_luci-i18n-filebrowser-zh-cn=y
CONFIG_PACKAGE_luci-app-rclone=y
CONFIG_PACKAGE_luci-i18n-rclone-zh-cn=y

# 8. 极客工具与“瑞士军刀” (Lucky/Gost/AdGuard/KMS)
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-gost=y
CONFIG_PACKAGE_luci-i18n-gost-zh-cn=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# 9. 网络诊断与测速 (Netspeedtest/WOL+/推送)
CONFIG_PACKAGE_luci-app-netspeedtest=y
CONFIG_PACKAGE_luci-i18n-netspeedtest-zh-cn=y
CONFIG_PACKAGE_luci-app-wolplus=y
CONFIG_PACKAGE_luci-i18n-wolplus-zh-cn=y
CONFIG_PACKAGE_luci-app-pushbot=y
CONFIG_PACKAGE_luci-i18n-pushbot-zh-cn=y
CONFIG_PACKAGE_luci-app-netdiagnostics=y
CONFIG_PACKAGE_luci-i18n-netdiagnostics-zh-cn=y

# 10. 软件商店与界面定制 (iStoreOS + Argon)
CONFIG_PACKAGE_luci-app-istoreos=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y

# 11. 系统监控与统计 (Netdata/Statistics)
CONFIG_PACKAGE_luci-app-netdata=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_luci-app-vnstat=y
CONFIG_PACKAGE_luci-i18n-vnstat-zh-cn=y

# 12. 固件打包设置 (1GB 巨型分区)
CONFIG_TARGET_IMAGES_GZ=n
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
