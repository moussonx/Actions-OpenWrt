# ============================================================================
# OpenWrt x86_64 优化配置文件 (XGATE 终极版)
# ============================================================================

CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ============================================================================
# 1. 虚拟机与硬件加速 (底层引擎)
# ============================================================================
CONFIG_VIRTIO=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_PACKAGE_qemu-ga=y
CONFIG_PACKAGE_acpid=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_kmod-virtio-balloon=y
CONFIG_PACKAGE_kmod-crypto-aes=y
CONFIG_PACKAGE_kmod-crypto-authenc=y
CONFIG_PACKAGE_kmod-lib-crc32c=y
CONFIG_PACKAGE_fstrim=y

# ============================================================================
# 2. 存储与磁盘管理 (吸收 e2fsprogs)
# ============================================================================
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# ============================================================================
# 3. 科学上网核心：Passwall 2 (吸收 ChinaDNS-NG)
# ============================================================================
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Sing-Box=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray_Binary=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ChinaDNS_NG=y

# ============================================================================
# 4. 高级网络管理与端口转发 (保留 socat 与 IPv6 桥接)
# ============================================================================
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-i18n-arpbind-zh-cn=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
CONFIG_PACKAGE_luci-app-wrtbwmon=y
CONFIG_PACKAGE_luci-i18n-wrtbwmon-zh-cn=y
CONFIG_PACKAGE_luci-app-onliner=y
CONFIG_PACKAGE_luci-i18n-onliner-zh-cn=y
CONFIG_PACKAGE_luci-app-socat=y
CONFIG_PACKAGE_luci-i18n-socat-zh-cn=y
CONFIG_PACKAGE_ipv6helper=y

# ============================================================================
# 5. 商店、穿透与高级工具
# ============================================================================
CONFIG_PACKAGE_luci-app-istoreos=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-app-cloudflared=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-app-alist=y
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_python3=y

# ============================================================================
# 6. 系统界面与优化
# ============================================================================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_zsh=y

# ============================================================================
# 7. 编译保命与底层网络协议 (吸收 IPv6 DHCP 增强)
# ============================================================================
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq-full_dhcpv6=y
# CONFIG_PACKAGE_kmod-mac80211 is not set
